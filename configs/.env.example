# .env.example
# Скопируйте этот файл в .env и заполните значениями

# Токен Telegram бота (обязательно)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Прокси (опционально, выберите один вариант)

# HTTP/HTTPS прокси
# HTTPS_PROXY=http://proxy-host:port

# SOCKS5 прокси (рекомендуется для NekoBox, Clash, Tor)
# SOCKS5_PROXY=127.0.0.1:2080
